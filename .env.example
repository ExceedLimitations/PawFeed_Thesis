# ── PawFeed environment variables ──────────────────────────────
# Copy this file to .env and fill in your values

# HTTP server port
PORT=3000

# MQTT broker URL  (local Mosquitto, HiveMQ, or your cloud broker)
MQTT_BROKER=mqtt://localhost:1883

# MQTT topics  (must match what your microcontroller publishes/subscribes)
MQTT_TOPIC_STATUS=pawfeed/status
MQTT_TOPIC_SENSOR=pawfeed/sensor
MQTT_TOPIC_CMD=pawfeed/command
